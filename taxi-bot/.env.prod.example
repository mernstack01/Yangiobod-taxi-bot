# Application
NODE_ENV=production
PORT=9000

# Database — set POSTGRES_PASSWORD in server env or override here
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/taxi_bot

# Telegram Bot
BOT_TOKEN=YOUR_BOT_TOKEN
ADMIN_TELEGRAM_IDS=YOUR_TELEGRAM_ID

# Telegram Super-Group (for topic broadcasting)
TELEGRAM_GROUP_ID=-100XXXXXXXXXX
TELEGRAM_GROUP_LINK=https://t.me/your_group

# Redis — internal Docker network, no port mapping needed
REDIS_URL=redis://redis:6379

# Business Logic
LISTING_EXPIRY_HOURS=2
CLIENT_LISTING_COOLDOWN_MINUTES=10
DRIVER_COOLDOWN_MINUTES=60

# Admin API
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRONG_SECRET
ADMIN_PANEL_URL=https://admin.yourdomain.com
